# =============================================================================
# SemesterSwap — Environment Variables Template
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# =============================================================================
# CORE BACKEND
# =============================================================================
PORT=8000

# Deployment environment: "development" | "production"
# Controls mock-admin endpoint visibility and other env-specific guards.
ENV=development

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL (Supabase) — use this in production.
DATABASE_URL=postgresql://username:password@db.<project-ref>.supabase.co:5432/postgres

# SQLite fallback for local development only (no external DB needed):
# DATABASE_URL=sqlite:///./semester_swap.db

# =============================================================================
# SUPABASE AUTH & STORAGE
# =============================================================================
# Found in Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Found in Supabase Dashboard → Project Settings → API → Project URL
# Used by backend for JWKS fetch (asymmetric token verification) and Supabase Storage.
SUPABASE_URL=https://your-project-ref.supabase.co

# Found in Supabase Dashboard → Project Settings → API → service_role (secret key)
# Required for backend server-side Supabase operations. Keep strictly private.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# FRONTEND (Vite) — Prefix VITE_ to expose to the browser bundle
# =============================================================================
# Found in Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Found in Supabase Dashboard → Project Settings → API → anon / public key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API base URL (no trailing slash)
# Development:  http://localhost:8000
# Production:   https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# =============================================================================
# CORS / FRONTEND URL (Backend)
# Set to your deployed frontend origin in production.
# Development:  http://localhost:5173
# Production:   https://yourdomain.com
# =============================================================================
FRONTEND_URL=http://localhost:5173

# =============================================================================
# AI PROVIDERS  (3-tier fallback: Anthropic → Groq → Google)
# At least one key is required for AI features (pricing, fraud, search).
# =============================================================================

# PRIMARY — Anthropic Claude
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SECONDARY FALLBACK — Groq (fast inference)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# TERTIARY FALLBACK — Google Gemini
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# =============================================================================
# EMAIL
# Choose one provider: RESEND or SMTP
# =============================================================================
EMAIL_PROVIDER=RESEND

# Sender identity displayed in outbound emails.
EMAIL_FROM=SemesterSwap <noreply@yourdomain.com>

# --- Resend (recommended for production) ---
# https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# --- SMTP (e.g. Gmail App Password or corporate relay) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_gmail_address@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# SMTP_USE_TLS=true

# --- Development safety override ---
# When set, ALL outbound emails are redirected to this address.
# Must be a verified sender in Resend. Remove or leave blank in production.
# EMAIL_OVERRIDE=your_test_email@example.com
