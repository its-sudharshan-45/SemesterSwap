# =============================================================================
# SemesterSwap — .gitattributes
# Single source of truth for line endings across all platforms.
# Overrides core.autocrlf for every developer on the team.
# Reference: https://git-scm.com/docs/gitattributes
# =============================================================================

# ---------------------------------------------------------------------------
# GLOBAL DEFAULT
# text=auto  → Git detects text vs binary automatically
# eol=lf     → normalise ALL detected text files to LF in the repository
# ---------------------------------------------------------------------------
* text=auto eol=lf

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
*.py   text eol=lf
*.pyi  text eol=lf

# ---------------------------------------------------------------------------
# TypeScript / JavaScript (Frontend — React + Vite)
# ---------------------------------------------------------------------------
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf

# ---------------------------------------------------------------------------
# Web — Styles & Markup
# ---------------------------------------------------------------------------
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.svg  text eol=lf

# ---------------------------------------------------------------------------
# Config & Data Formats
# ---------------------------------------------------------------------------
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.ini  text eol=lf
*.env  text eol=lf

# ---------------------------------------------------------------------------
# SQL
# ---------------------------------------------------------------------------
*.sql  text eol=lf

# ---------------------------------------------------------------------------
# Shell Scripts — CRLF breaks bash/sh on Unix
# ---------------------------------------------------------------------------
*.sh   text eol=lf

# ---------------------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------------------
*.md   text eol=lf
*.txt  text eol=lf
*.rst  text eol=lf

# ---------------------------------------------------------------------------
# Windows-native scripts — cmd.exe requires CRLF
# ps1 does NOT require CRLF; PowerShell 7+ runs on Linux/macOS too.
# Store ps1 as LF to keep them portable.
# ---------------------------------------------------------------------------
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=lf

# ---------------------------------------------------------------------------
# Lock files — treat as text but never diff (too noisy)
# ---------------------------------------------------------------------------
package-lock.json  text eol=lf -diff
yarn.lock          text eol=lf -diff

# ---------------------------------------------------------------------------
# Binary — images, fonts, archives, compiled assets, databases
# Git will never touch line endings for these.
# ---------------------------------------------------------------------------
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.7z     binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.db     binary
*.sqlite binary
*.sqlite3 binary
