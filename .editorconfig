# =============================================================================
# SemesterSwap — .editorconfig
# Editor-agnostic coding style enforcement. Supported by VS Code, PyCharm,
# Vim, Neovim, Emacs, Sublime Text, and most modern IDEs natively.
# Reference: https://editorconfig.org
# =============================================================================
root = true

# ---------------------------------------------------------------------------
# GLOBAL DEFAULTS — applied to all files unless overridden below
# ---------------------------------------------------------------------------
[*]
charset             = utf-8
end_of_line         = lf
indent_style        = space
indent_size         = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ---------------------------------------------------------------------------
# Python — PEP 8 mandates 4-space indentation
# ---------------------------------------------------------------------------
[*.{py,pyi}]
indent_size = 4
max_line_length = 88

# ---------------------------------------------------------------------------
# TypeScript / JavaScript (Vite + React — Prettier default is 2 spaces)
# ---------------------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs}]
indent_size = 2

# ---------------------------------------------------------------------------
# CSS / SCSS
# ---------------------------------------------------------------------------
[*.{css,scss}]
indent_size = 2

# ---------------------------------------------------------------------------
# HTML — Prettier default
# ---------------------------------------------------------------------------
[*.html]
indent_size = 2

# ---------------------------------------------------------------------------
# Config & Data Formats
# ---------------------------------------------------------------------------
[*.{json,yaml,yml,toml}]
indent_size = 2

# ---------------------------------------------------------------------------
# SQL — 2-space convention widely used in migrations
# ---------------------------------------------------------------------------
[*.sql]
indent_size = 2

# ---------------------------------------------------------------------------
# Markdown — trailing whitespace is meaningful (line break = 2 spaces + newline)
# Do NOT trim trailing whitespace in .md files.
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ---------------------------------------------------------------------------
# Shell Scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_size = 2
shell_variant = bash

# ---------------------------------------------------------------------------
# Windows Scripts — CRLF required by cmd.exe
# ---------------------------------------------------------------------------
[*.{bat,cmd}]
end_of_line = crlf

# ---------------------------------------------------------------------------
# Makefiles — tabs are syntactically required
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ---------------------------------------------------------------------------
# Lock files — auto-generated, editors should not reformat
# ---------------------------------------------------------------------------
[{package-lock.json,yarn.lock}]
insert_final_newline = false
